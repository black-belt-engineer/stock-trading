# Copy to `.env.local` and customize (`.env.local` is gitignored).
# Use `docker compose --env-file .env.local up -d` so Compose interpolates variables here.

# --- Kafka (Redpanda in docker-compose; apps on host use localhost) ---
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=stock-prices
# apps/consumer — must differ from the dashboard consumer group if both run from the same env file.
KAFKA_GROUP_ID=stock-prices-consumer
# apps/dashboard — separate key so it never shares a group with the consumer.
# DASHBOARD_KAFKA_GROUP_ID=stock-prices-dashboard
KAFKA_CLIENT_ID=ingestor
KAFKA_TOPIC_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# --- Redis ---
# From host:
REDIS_URL=redis://localhost:6379
# From another container on stock-net, use instead:
# REDIS_URL=redis://redis:6379

# --- Postgres ---
# From host:
DATABASE_URL=postgresql://stockuser:stockpass@localhost:5432/stockdb
# From another container on stock-net, use instead:
# DATABASE_URL=postgresql://stockuser:stockpass@postgres:5432/stockdb

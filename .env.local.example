# Copy to `.env.local` and customize (`.env.local` is gitignored).
# Use `docker compose --env-file .env.local up -d` so Compose interpolates variables here.

# --- Google Cloud Pub/Sub (emulator) ---
PUBSUB_PROJECT_ID=local-project
PUBSUB_TOPIC=stock-prices
PUBSUB_SUBSCRIPTION=stock-prices-sub

# Client SDKs need this to reach the emulator (host:port).
# Inside Docker network (ingestor/consumer containers): use the service name.
# On your host machine (Node apps run locally): use localhost.
PUBSUB_EMULATOR_HOST=localhost:8085

# --- Redis ---
# From host:
REDIS_URL=redis://localhost:6379
# From another container on stock-net, use instead:
# REDIS_URL=redis://redis:6379

# --- Postgres ---
# From host:
DATABASE_URL=postgresql://stockuser:stockpass@localhost:5432/stockdb
# From another container on stock-net, use instead:
# DATABASE_URL=postgresql://stockuser:stockpass@postgres:5432/stockdb
